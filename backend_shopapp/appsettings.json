{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Server=<db_host>,<db_port>;Database=<db_name>;User Id=<db_username>;Password=<db_password>;TrustServerCertificate=True;",
    "Redis": "<redis_host>:<redis_port>"
  },
  "Jwt": {
    "Key": "<jwt_key>",
    "Issuer": "<jwt_Issuer>",
    "Audience": "<jwt_Audience>"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "<sender_name>",
    "SenderEmail": "<email>",
    "Password": "<password>"
  },
  "//": "Register merchant env test Vnpay at: https://sandbox.vnpayment.vn/devreg/",
  "//": "Access: https://sandbox.vnpayment.vn/vnpaygw-sit-testing, config IPN URL set is 'http://<backend_host>:<backend_port>'.",
  "Vnpay": {
    "TmnCode": "<vnpay_TmnCode>",
    "HashSecret": "<vnpay_HashSecret>",
    "BaseUrl": "<vnpay_BaseUrl>",
    "Command": "pay",
    "CurrCode": "VND",
    "Version": "2.1.0",
    "Locale": "vn",
    "ReturnUrl": "http://<backend_host>:<backend_port>/api/v1/payment/vnpay-return"
  },
  "TimeZoneId": "SE Asia Standard Time"
}
